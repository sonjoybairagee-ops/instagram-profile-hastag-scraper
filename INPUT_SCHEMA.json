{
  "title": "YouTube Scraper Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "searchQueries": {
      "title": "Search Queries",
      "type": "array",
      "description": "YouTube search keywords",
      "editor": "stringList",
      "prefill": ["python tutorial 2024"]
    },
    "channelUrls": {
      "title": "Channel URLs",
      "type": "array",
      "description": "YouTube channel URLs to scrape",
      "editor": "stringList",
      "prefill": []
    },
    "videoUrls": {
      "title": "Video URLs",
      "type": "array",
      "description": "Direct YouTube video URLs",
      "editor": "stringList",
      "prefill": []
    },
    "maxVideosPerChannel": {
      "title": "Max Videos Per Channel",
      "type": "integer",
      "description": "Maximum videos to scrape per channel",
      "default": 30,
      "minimum": 1,
      "maximum": 500
    },
    "maxResultsPerSearch": {
      "title": "Max Results Per Search",
      "type": "integer",
      "description": "Maximum videos per search query",
      "default": 20,
      "minimum": 1,
      "maximum": 100
    },
    "scrapeComments": {
      "title": "Scrape Comments",
      "type": "boolean",
      "description": "Extract top comments from each video",
      "default": false
    },
    "maxCommentsPerVideo": {
      "title": "Max Comments Per Video",
      "type": "integer",
      "description": "Maximum comments per video",
      "default": 20,
      "minimum": 1,
      "maximum": 100
    },
    "scrapeChannel": {
      "title": "Scrape Channel Info",
      "type": "boolean",
      "description": "Extract channel details (subscribers, description, etc)",
      "default": true
    },
    "proxyConfiguration": {
      "title": "Proxy Configuration",
      "type": "object",
      "description": "Proxy settings",
      "editor": "proxy",
      "prefill": { "useApifyProxy": false }
    }
  }
}
